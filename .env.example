# Cartridge-2 Environment Variables
# Copy this file to .env and customize for your local development environment.
# NEVER commit .env to version control - it may contain secrets!

# ============================================================================
# PostgreSQL Database
# ============================================================================
# For local development with docker-compose:
POSTGRES_PASSWORD=change_me_in_local_env

# For direct connection (if not using docker-compose defaults):
# CARTRIDGE_STORAGE_POSTGRES_URL=postgresql://cartridge:your_password@localhost:5432/cartridge

# ============================================================================
# MinIO (S3-compatible storage for models in K8s deployment)
# ============================================================================
# These credentials are used for both MinIO server AND AWS S3 client access
# IMPORTANT: Change these from defaults for production deployments
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_secure_random_password

# AWS-style credentials (should match MINIO_ROOT_USER/PASSWORD)
# These are used by the S3 client libraries
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}

# ============================================================================
# CORS Configuration
# ============================================================================
# For production, set to your actual frontend domain(s):
# CARTRIDGE_WEB_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
#
# For local development, leave empty or unset to allow all origins (with warning)

# ============================================================================
# AWS/GCS credentials (for S3 backend in production)
# ============================================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ============================================================================
# Actor Health Check
# ============================================================================
# ACTOR_HEALTH_PORT=8081
